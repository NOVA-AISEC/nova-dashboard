# Frontend build-time data source switch.
# Default behavior when unset is mock mode because src/api/index.ts
# only uses the HTTP client when this is exactly "false".
VITE_USE_MOCK=true

# Optional stakeholder gate for hosted demos.
# Leave blank to disable it entirely.
VITE_DEMO_PASSWORD=

# Local Express API port used by:
# - server/index.js
# - vite.config.ts dev proxy
DAMA_API_PORT=8787

# Local simulator controls for server/ only.
SIMULATOR_ENABLED=true
SIMULATOR_INTERVAL_MS=8000
